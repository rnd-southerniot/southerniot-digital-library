{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://southerniot.local/dpl/schemas/alerting.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["channels", "routing"],
  "properties": {
    "channels": {
      "type": "object",
      "additionalProperties": false,
      "required": ["crm_comments", "email", "mattermost"],
      "properties": {
        "crm_comments": { "type": "boolean" },
        "email": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "to_roles"],
          "properties": {
            "enabled": { "type": "boolean" },
            "to_roles": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string" }
            },
            "subject_prefix": { "type": "string" }
          }
        },
        "mattermost": {
          "type": "object",
          "additionalProperties": false,
          "required": ["enabled", "channel"],
          "properties": {
            "enabled": { "type": "boolean" },
            "server": { "type": "string" },
            "channel": { "type": "string" }
          }
        }
      }
    },
    "routing": {
      "type": "object",
      "additionalProperties": false,
      "required": ["blocker", "warning", "info"],
      "properties": {
        "blocker": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "warning": { "type": "array", "minItems": 1, "items": { "type": "string" } },
        "info": { "type": "array", "minItems": 1, "items": { "type": "string" } }
      }
    }
  }
}
