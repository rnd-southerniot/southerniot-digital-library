{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://southerniot.local/dpl/schemas/error-envelope.schema.json",
  "title": "SouthernIoT Deterministic Error Envelope",
  "type": "object",
  "additionalProperties": false,
  "required": ["status", "error", "meta"],
  "properties": {
    "status": {
      "type": "string",
      "const": "error"
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "message", "category", "retriable"],
      "properties": {
        "code": {
          "type": "string",
          "pattern": "^[A-Z0-9_]{3,64}$"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "category": {
          "type": "string",
          "enum": [
            "validation",
            "integration",
            "conflict",
            "not_found",
            "authorization",
            "rate_limit",
            "internal"
          ]
        },
        "retriable": {
          "type": "boolean"
        },
        "causes": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["code", "message"],
            "properties": {
              "code": {
                "type": "string",
                "pattern": "^[A-Z0-9_]{3,64}$"
              },
              "message": {
                "type": "string",
                "minLength": 1
              },
              "field": {
                "type": "string"
              }
            }
          }
        },
        "details": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": ["request_id", "timestamp", "service", "version"],
      "properties": {
        "request_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]{8,128}$"
        },
        "trace_id": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.:-]{8,128}$"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "service": {
          "type": "string",
          "enum": ["crm-ingestion", "dpl-search", "dpl-export", "validator"]
        },
        "version": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "source_event_id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.:-]{8,128}$"
    }
  }
}
