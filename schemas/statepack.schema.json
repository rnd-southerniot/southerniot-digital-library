{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://southerniot.local/dpl/schemas/statepack.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "state",
    "objective",
    "roles",
    "steps",
    "required_inputs",
    "required_evidence",
    "outputs"
  ],
  "properties": {
    "state": {
      "type": "string",
      "enum": [
        "initialized",
        "site_survey",
        "hardware_preparation",
        "firmware_generate",
        "lab_test",
        "ready_for_installation",
        "on_site_installation",
        "testing",
        "live",
        "maintenance"
      ]
    },
    "objective": { "type": "string" },
    "roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "enum": [
          "CTO",
          "RND_LEAD",
          "RND_ENGINEER",
          "FIELD_ENGINEER",
          "PROJECT_LEAD",
          "SUPPORT",
          "OPS"
        ]
      }
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "required_inputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "required_evidence": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "photos_min": { "type": "integer", "minimum": 0 },
        "photos_max": { "type": "integer", "minimum": 0 },
        "required_photo_tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },
    "outputs": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "notes": { "type": "string" }
  }
}
