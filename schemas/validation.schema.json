{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://southerniot.local/dpl/schemas/validation.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": ["validation_id", "severity", "when_state", "rules", "message"],
  "properties": {
    "validation_id": { "type": "string" },
    "severity": { "type": "string", "enum": ["blocker", "warning", "info"] },
    "when_state": {
      "type": "string",
      "enum": [
        "initialized",
        "site_survey",
        "hardware_preparation",
        "firmware_generate",
        "lab_test",
        "ready_for_installation",
        "on_site_installation",
        "testing",
        "live",
        "maintenance"
      ]
    },
    "rules": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    },
    "message": { "type": "string" }
  }
}
